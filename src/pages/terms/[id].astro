---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from 'astro:content';
import TermCitation from "../../components/TermCitation.astro";
import {formatDate} from "../../utils/formatDate";
import { Markdown } from '@astropub/md'
import SeeAlso from "../../components/SeeAlso.astro";

export async function getStaticPaths() {
    const terms = await getCollection('terms');
    return terms.map(term => ({
        params: { id: term.id },
        props: { term },
    }));
}

const { term } = Astro.props;
const { Content } = await render(term);
const citationAuthors = term.data.author?.split(' and ').map(author => author.trim());
---
<BaseLayout pageTitle={term.data.title + ' | LGDN'}>
    <Fragment slot="head">
        <meta name="description" content={term.data.description} />

        <meta name="citation_title" content={term.data.title} />
        <meta name="citation_journal_title" content="The Living Glossary of Digital Narrative" />
        <meta name="citation_abstract" content={term.data.description} />
        <meta name="citation_language" content="en" />
        <meta name="citation_fulltext_html_url" content={`https://glossary.cdn.uib.no/terms/${term.id}`} />
        {citationAuthors?.map(author => <meta name="citation_author" content={author} />)}
        {term.data.pubDate && <meta name="citation_publication_date" content={term.data.pubDate.toISOString().slice(0, 10).replace(/-/g, '/')} />}

        <meta property="og:type" content="article" />
        <meta property="og:site_name" content="The Living Glossary of Digital Narrative" />
        <meta property="og:title" content={term.data.title} />
        <meta property="og:description" content={term.data.description} />
        <meta property="og:url" content={`https://glossary.cdn.uib.no/terms/${term.id}`} />

        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={term.data.title} />
        <meta name="twitter:description" content={term.data.description} />
    </Fragment>
    <div class="container p-2 md:p-0">
        <div class="flex flex-col items-center">
            <article class="prose dark:prose-invert xl:prose-lg my-8 data-pagefind-body">
                <h1 style="margin-bottom: 0" class="text-4xl lg:text-7xl xl:text-8xl font-bold">{term.data.title}</h1>
                <p>
                    <em>{term.data.description}</em>
                    <br>
                    {term.data.author && <span>{term.data.author}</span>}
                    {term.data.pubDate && <span>{formatDate(term.data.pubDate)}</span>}
                </p>

                <h2 id="explication">Explication</h2>
                <Content />

                <SeeAlso seeAlso={term.data.seeAlso} />

                {term.data.worksReferenced && (
                    <h2 id="works-referenced">Works Referenced</h2>
                    <Markdown of={term.data.worksReferenced} />
                )}

                {term.data.furtherReading && (
                        <h2 id="further-reading">Further Reading</h2>
                        <Markdown of={term.data.furtherReading} />
                )}

                <TermCitation term={term} />

                {(!term.data.author || !term.data.pubDate) &&
                    <div class="border-t not-prose pt-6">
                        <p>You're in luck! There's no explication for this term and you can be the one write it! <a href="/submit" class="underline hover:no-underline font-bold text-accent-blue">Submit</a></p>
                    </div>
                }

                {term.data.author && term.data.pubDate &&
                    <p class="not-prose mt-4 border-t pt-6 text-sm">Text is available under the <a class="underline hover:no-underline" href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank">Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International</a></p>
                }
            </article>
        </div>
    </div>
</BaseLayout>
